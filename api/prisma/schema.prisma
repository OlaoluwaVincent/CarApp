
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  role           UserRole @default(CUSTOMER)
  hashedPassword String
}

model CarImage {
  id      String @id @default(uuid())
  images  String[]
  carId   String @unique
  car     Car    @relation(fields: [carId], references: [id])
}

model Car {
  id             String    @id @default(uuid())
  name           String
  carType        String
  steering       String
  capacity       String
  gasoline       String
  amount         String
  description    String
  tag            String?
  tagDescription String?
  carImage       CarImage?
}
